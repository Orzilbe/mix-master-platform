# ── Clerk ──────────────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/join
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/join

# ── Supabase ────────────────────────────────────────────────────────────────────
# Get from: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://[project-id].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ── Game Server ─────────────────────────────────────────────────────────────────
# Your game server URL (Render / home server / ngrok)
NEXT_PUBLIC_GAME_SERVER_URL=https://mix-master-8gh1.onrender.com

# ── Platform ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://mix-master-gray.vercel.app

# ── Security ────────────────────────────────────────────────────────────────────
# Random secret shared between platform and game server
# Generate with: openssl rand -hex 32
GAME_API_SECRET=your_random_secret_here

# ── Admin ───────────────────────────────────────────────────────────────────────
# Clerk user IDs of admins (comma-separated for multiple admins)
# To add a second admin: ADMIN_USER_IDS=user_abc123,user_xyz789
# Any user can find their own Clerk ID by visiting /api/debug-user
ADMIN_USER_IDS=user_...
